{
  "name": "bugfix-orchestrator-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "npm run test:unit && npm run test:integration && npm run test:acceptance",
    "test:unit": "vitest run --passWithNoTests tests/unit",
    "test:integration": "vitest run --passWithNoTests tests/integration",
    "test:acceptance": "vitest run tests/acceptance",
    "cli:run": "npm run build && node dist/cli/bin.js"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
